# Google Tag Manager — crear contenedor en tagmanager.google.com y pegar el ID aquí.
# Dentro de GTM se configuran GA4, Google Ads y Meta Pixel escuchando los eventos:
#   whatsapp_click, generate_lead, quiz_complete, beca_click
# En Vercel: Settings → Environment Variables → NEXT_PUBLIC_GTM_ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
